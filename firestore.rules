rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Auth tokens do not contain roles. Fetch from trusted user doc.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'no.madyauta@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'Admin')
      );
    }
    
    function isTechnician() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'Technician')
      );
    }

    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'role']) &&
               data.email is string && data.email.size() < 256 &&
               data.displayName is string && data.displayName.size() < 128 &&
               data.role in ['Admin', 'Technician', 'Client'];
      }
      
      allow get: if isSignedIn() && (isOwner(userId) || isTechnician());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role']) && isValidUser(incoming())) ||
        isAdmin()
      );
    }

    // Jobs
    match /jobs/{jobId} {
      function isValidJob(data) {
        return data.keys().hasAll(['jobId', 'name', 'site', 'shift', 'status', 'createdAt', 'updatedAt', 'createdBy']) &&
               data.jobId is string && data.jobId.size() < 50 &&
               data.name is string && data.name.size() < 256 &&
               data.status in ['Open', 'In-Process', 'Completed'] &&
               data.createdBy == request.auth.uid;
      }
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isTechnician() && isValidJob(incoming());
      allow update: if isTechnician() && isValidJob(incoming()) && (
        incoming().createdBy == existing().createdBy // Immutable owner
      );
      allow delete: if isAdmin();
    }

    // Samples
    match /samples/{sampleId} {
      function isValidSample(data) {
        return data.keys().hasAll(['jobId', 'sampleId', 'clientName', 'status', 'sampleType', 'source', 'priority', 'submittedById', 'history', 'createdAt', 'updatedAt']) &&
               data.sampleId is string && data.sampleId.size() < 64 &&
               data.status in ['Received', 'Preparation', 'Analysis', 'Finalized', 'Cancelled'] &&
               data.history is list && data.history.size() <= 100;
      }
      
      // Client Isolation
      allow get: if isSignedIn() && (isTechnician() || existing().clientName == getUserData().displayName);
      allow list: if isSignedIn() && (isTechnician() || resource.data.clientName == getUserData().displayName);
      
      allow create: if isTechnician() && isValidSample(incoming()) && incoming().submittedById == request.auth.uid;
      allow update: if isTechnician() && isValidSample(incoming()) && (
        incoming().submittedById == existing().submittedById && // Immutable owner
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'elements', 'updatedAt', 'history', 'method', 'methodData', 'physicalProperties'])
      );
      allow delete: if isAdmin();
    }

    // Requisitions
    match /requisitions/{reqId} {
      function isValidRequisition(data) {
        return data.keys().hasAll(['itemId', 'itemName', 'quantityRequested', 'unit', 'status', 'requestedBy', 'requestedByUserName', 'createdAt', 'updatedAt']) &&
               data.itemId is string && isValidId(data.itemId) &&
               data.quantityRequested is number && data.quantityRequested > 0 &&
               data.status in ['Pending', 'Approved', 'Ordered', 'Received', 'Cancelled'] &&
               data.requestedBy == request.auth.uid;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRequisition(incoming());
      allow update: if isTechnician() && (
        incoming().requestedBy == existing().requestedBy &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    // Invoices
    match /invoices/{invoiceId} {
      function isValidInvoice(data) {
        return data.keys().hasAll(['invoiceNumber', 'clientId', 'clientName', 'date', 'dueDate', 'status', 'items', 'subtotal', 'tax', 'total']) &&
               data.invoiceNumber is string && data.invoiceNumber.size() < 20 &&
               data.status in ['Draft', 'Sent', 'Paid', 'Overdue', 'Cancelled'] &&
               data.total is number && data.total >= 0;
      }

      allow get: if isSignedIn() && (isAdmin() || existing().clientName == getUserData().displayName);
      allow list: if isSignedIn() && (isAdmin() || resource.data.clientName == getUserData().displayName);
      
      allow create: if isAdmin() && isValidInvoice(incoming());
      allow update: if isAdmin() && isValidInvoice(incoming());
      allow delete: if isAdmin();
    }

    // Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isTechnician();
    }

    // Marketing Assets
    match /hero_config/{imgId} {
      allow read: if true; // Publicly accessible for the landing page
      allow write: if isAdmin();
    }
  }
}
